# LLM Provider: "ollama" (default, local) or "groq" (fast, free tier)
LLM_PROVIDER=ollama

# Model name
#   ollama: e.g. llama3.2:3b, llama3.1:8b, qwen2.5:7b
#   groq:   e.g. llama-3.3-70b-versatile, llama3-8b-8192
LLM_MODEL=llama3.2:3b

# Groq API key (required only when LLM_PROVIDER=groq)
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=

# SigNoz MCP API key (keep default unless you regenerated it)
SIGNOZ_API_KEY=dbe4dc0e-69a7-4245-81cc-37ad39178e04
